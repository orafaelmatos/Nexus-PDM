<UserControl x:Class="GestorAddin.UI.ChangesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <DockPanel Grid.Row="0" Margin="5">
            <TextBlock Text="Projects:" VerticalAlignment="Center" Margin="0,0,5,0"/>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="RefreshButton" 
                        Click="Refresh_Click"
                        Padding="5,0"
                        Margin="5,0,0,0"
                        Background="Transparent"
                        BorderBrush="Transparent">
                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                </Button>
            </StackPanel>

            <ComboBox x:Name="ProjectCombo"
                      SelectionChanged="ProjectCombo_SelectionChanged"/>
        </DockPanel>

        <!-- Changes Tree -->
        <TreeView x:Name="ChangesTree"
                  Grid.Row="1"
                  BorderBrush="#DDD"
                  Margin="5,0,5,5">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="Padding" Value="0,2"/>
                    <Setter Property="IsExpanded" Value="True"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <!-- Commit Area -->
        <StackPanel Grid.Row="2" Margin="5">
            <TextBox x:Name="CommitMessage" 
                     Height="60" 
                     AcceptsReturn="True" 
                     Tag="Commit message..."
                     Margin="0,0,0,5"
                     VerticalScrollBarVisibility="Auto"/>
            <Button x:Name="CheckInButton" 
                    Content="Check-In" 
                    Padding="10,5" 
                    Click="CheckIn_Click"
                    Background="#007ACC"
                    Foreground="White"/>
        </StackPanel>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="2"
              Background="#80FFFFFF"
              Visibility="Collapsed">
            <TextBlock Text="Loading..."
                       FontSize="16"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>
    </Grid>

</UserControl>
